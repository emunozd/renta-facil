# .env.example
# Copia este archivo como .env y completa los valores

# ─── OBLIGATORIO ──────────────────────────────────────────────
# Token de tu bot de Telegram (obtenerlo con @BotFather)
TELEGRAM_TOKEN=tu_token_aqui

# ─── IA LOCAL (kingsrow_ai_base.py) ──────────────────────────
AI_BASE_URL=http://localhost:8181
AI_API_KEY=                          # dejar vacio si no configuraste API key
AI_MODEL=mlx-community/Qwen3.5-35B-A3B-4bit
AI_MAX_TOKENS=4096
AI_TIMEOUT_SECONDS=120

# ─── RAG ─────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/data/renta-facil/chroma
PDF_FORMULARIO_PATH=/data/renta-facil/formulario_210.pdf
# Modelo de embeddings multilingue (espanol funciona bien)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_TOP_K=5
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=80

# ─── WATCHER ─────────────────────────────────────────────────
# Cada cuantos segundos verificar si el PDF cambio (300 = 5 min)
PDF_WATCH_INTERVAL=300

# ─── BASE DE DATOS ───────────────────────────────────────────
DB_PATH=/data/renta-facil/sesiones.db

# ─── LIMITES ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
